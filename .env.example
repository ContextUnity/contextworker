# =============================================================================
# ContextWorker Environment Configuration
# =============================================================================
# Copy to `.env` and fill in your values.
#
# PRECEDENCE: worker.yml > .env > defaults
# Non-secret settings can be moved to worker.yml (see worker.yaml.example).
# If a key exists in both .env and worker.yml, the YAML file wins.
# SECRETS (API keys, passwords) MUST stay here — never put them in worker.yml.

# ===== Service Identity =====
SERVICE_NAME=contextworker
SERVICE_VERSION=0.1.0
LOG_LEVEL=INFO

# ===== Temporal (REQUIRED) =====
TEMPORAL_HOST=localhost:7233

# ===== Worker gRPC Server =====
# WORKER_PORT=50052                      # gRPC listen port
# WORKER_HOST=0.0.0.0                   # Bind address
# WORKER_INSTANCE_NAME=default
# WORKER_TENANTS=tenant_a,tenant_b   # Comma-separated tenant list

# ===== Platform Services =====
# CU_BRAIN_GRPC_URL=localhost:50051      # Override for remote Brain

# ===== Redis (for queue and batch tracking) =====
REDIS_URL=redis://localhost:6379/0

# ===== OpenTelemetry (optional) =====
OTEL_ENABLED=false
# OTEL_ENDPOINT=http://localhost:4317
